<metadata>
  <!--
    Solo necesitamos TvControlManager (i2c_init + i2c_read) para NFC.
    Excluir todo lo demas elimina los errores y warnings de binding.
  -->

  <!-- Paquetes completos que no usamos -->
  <remove-node path="/api/package[@name='rockchip.hardware.dazzle.v1_0']" />
  <remove-node path="/api/package[@name='rockchip.hardware.hdmi.v1_0']" />
  <remove-node path="/api/package[@name='android.hidl.base.v1_0']" />
  <remove-node path="/api/package[@name='vendor.amlogic.hardware.tvserver.v1_0']" />
  <remove-node path="/api/package[@name='com.droidlogic.tvinput.services']" />

  <!-- Dentro de com.droidlogic.app.tv: solo TvControlManager -->
  <remove-node path="/api/package[@name='com.droidlogic.app.tv']/class[@name!='TvControlManager']" />
  <remove-node path="/api/package[@name='com.droidlogic.app.tv']/interface" />

</metadata>
