# Copiá este archivo a  .env  en la Pi (~/docker/kiosk/.env) y completá los valores.
# El .env NO se versiona (secretos). docker compose lo lee automaticamente.

NEXTCLOUD_URL=http://192.168.1.50:8181
NEXTCLOUD_PUBLIC_URL=https://lanube.uno/app
ADMIN_PASSWORD=CAMBIAR_ESTA_CLAVE
# F5: secreto que los paneles mandan en /panel-ping (debe coincidir con
# PanelSecret en apk/MainActivity.cs). Vacio = se acepta cualquier ping.
PANEL_SECRET=lanube-panel-2026
# COOKIE_DOMAIN=            # opcional, normalmente vacio (dominio unico)
